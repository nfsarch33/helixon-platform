{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Qwen3.6-27B fleet health: cells up/down, queue depth, request latency, GPU mem, cost per call.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Cells Ready",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(qwen36_cell_ready)",
          "legendFormat": "ready",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 3}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background"
      }
    },
    {
      "type": "stat",
      "title": "Cells Blocked",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(qwen36_cell_blocked)", "legendFormat": "blocked", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    },
    {
      "type": "stat",
      "title": "In-Flight Requests",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(qwen36_inflight_requests)", "legendFormat": "inflight", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}
    },
    {
      "type": "stat",
      "title": "5xx Rate (5m)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(qwen36_request_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(qwen36_request_total[5m])), 1e-9)",
          "legendFormat": "5xx_ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    },
    {
      "type": "timeseries",
      "title": "Request latency p50/p95/p99 (s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(qwen36_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(qwen36_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(qwen36_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "s"}
      }
    },
    {
      "type": "timeseries",
      "title": "Tokens / sec (input vs output)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(qwen36_input_tokens_total[5m]))",
          "legendFormat": "input_tps",
          "refId": "A"
        },
        {
          "expr": "sum(rate(qwen36_output_tokens_total[5m]))",
          "legendFormat": "output_tps",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}
      }
    },
    {
      "type": "timeseries",
      "title": "GPU mem free (MiB) by cell",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "qwen36_gpu_mem_free_mib",
          "legendFormat": "{{cell_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "decmbytes"}
      }
    },
    {
      "type": "timeseries",
      "title": "Cost USD / hour (estimate)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(qwen36_est_cost_usd_total[1h])) * 3600",
          "legendFormat": "usd_per_hour",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "currencyUSD"}
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["helixon", "qwen36", "fleet"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "qwen36-fleet",
  "uid": "qwen36-fleet",
  "version": 1,
  "weekStart": ""
}